---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Koios · Colour palette"
  description="The Koios design system — the locked KOIOS Warm purple, warm paper neutrals, the brand-book secondary accent and semantic signals."
  page="palette"
>

<section class="pal-hero">
  <div class="wrap">
    <span class="eyebrow">Design system</span>
    <h1 style="margin-top:16px;font-size:clamp(36px,5vw,56px)">The Koios palette.</h1>
    <p class="lead" style="margin-top:18px">Anchored by the locked KOIOS Warm purple and warm paper neutrals, with one explorable secondary drawn from the brand-book palette and a tight set of semantic signals. Colour is used sparingly &mdash; if it appears, it&rsquo;s saying something.</p>
  </div>
</section>

<!-- BRAND BOOK SOURCE -->
<section class="pal-sec">
  <div class="wrap">
    <h2>From the brand book</h2>
    <p class="sub">The six authoritative KOIOS colours, with Pantone references. <b>Warm purple</b> is the locked primary; the other five are the source for the secondary accent below.</p>
    <div class="swatches">
      <div class="sw"><div class="chip" style="background:#5B112F"></div><div class="meta"><div class="nm">Warm purple <span class="star">&#9733;</span></div><div class="hex">#5B112F</div><div class="tok">PMS 209 C &middot; primary</div></div></div>
      <div class="sw"><div class="chip" style="background:#D25137"></div><div class="meta"><div class="nm">Vibrant orange</div><div class="hex">#D25137</div><div class="tok">PMS 7625 C</div></div></div>
      <div class="sw"><div class="chip" style="background:#DC9A61"></div><div class="meta"><div class="nm">Fresh yellow</div><div class="hex">#DC9A61</div><div class="tok">PMS 1365 C</div></div></div>
      <div class="sw"><div class="chip" style="background:#2A634D"></div><div class="meta"><div class="nm">Wood green</div><div class="hex">#2A634D</div><div class="tok">PMS 7727 C</div></div></div>
      <div class="sw ring"><div class="chip" style="background:#E4C1D5"></div><div class="meta"><div class="nm">Bubbly pink</div><div class="hex">#E4C1D5</div><div class="tok">PMS 217 C</div></div></div>
      <div class="sw ring"><div class="chip" style="background:#CCD2EA"></div><div class="meta"><div class="nm">Sky blue</div><div class="hex">#CCD2EA</div><div class="tok">PMS 7444 C</div></div></div>
    </div>
  </div>
</section>

<!-- BRAND -->
<section class="pal-sec">
  <div class="wrap">
    <h2>Brand maroon</h2>
    <p class="sub">The locked KOIOS colour &mdash; <b>Warm purple</b>, PMS 209 C, <span class="mono">#5B112F</span> &mdash; and its tonal range. Used for headline accents, primary actions, the logo and dark sections.</p>
    <div class="swatches">
      <div class="sw"><div class="chip" style="background:#2A0816"></div><div class="meta"><div class="nm">Maroon 900</div><div class="hex">#2A0816</div><div class="tok">--primary-deeper</div></div></div>
      <div class="sw"><div class="chip" style="background:#3A0B1E"></div><div class="meta"><div class="nm">Maroon 800</div><div class="hex">#3A0B1E</div><div class="tok">--primary-deep</div></div></div>
      <div class="sw"><div class="chip" style="background:#5B112F"></div><div class="meta"><div class="nm">Warm purple <span class="star">&#9733;</span></div><div class="hex">#5B112F</div><div class="tok">--primary</div></div></div>
      <div class="sw"><div class="chip" style="background:#842048"></div><div class="meta"><div class="nm">Maroon 600</div><div class="hex">#842048</div><div class="tok">--primary-bright</div></div></div>
      <div class="sw"><div class="chip" style="background:#B06A82"></div><div class="meta"><div class="nm">Maroon 300</div><div class="hex">#B06A82</div><div class="tok">tint</div></div></div>
      <div class="sw"><div class="chip" style="background:#E6D5DB"></div><div class="meta"><div class="nm">Maroon 100</div><div class="hex">#E6D5DB</div><div class="tok">hover border</div></div></div>
    </div>
  </div>
</section>

<!-- PAPER -->
<section class="pal-sec">
  <div class="wrap">
    <h2>Paper &amp; neutrals</h2>
    <p class="sub">Warm cream surfaces and hairline rules carry the &ldquo;clinical paper&rdquo; feel &mdash; depth comes from line weight and surface tone, not heavy shadow.</p>
    <div class="swatches">
      <div class="sw ring"><div class="chip" style="background:#F3EFE9"></div><div class="meta"><div class="nm">Canvas</div><div class="hex">#F3EFE9</div><div class="tok">--bg</div></div></div>
      <div class="sw ring"><div class="chip" style="background:#EAE3D8"></div><div class="meta"><div class="nm">Recessed</div><div class="hex">#EAE3D8</div><div class="tok">--bg-dark</div></div></div>
      <div class="sw ring"><div class="chip" style="background:#FBF8F3"></div><div class="meta"><div class="nm">Surface</div><div class="hex">#FBF8F3</div><div class="tok">--surface</div></div></div>
      <div class="sw ring"><div class="chip" style="background:#FFFFFF"></div><div class="meta"><div class="nm">Card</div><div class="hex">#FFFFFF</div><div class="tok">--surface-2</div></div></div>
      <div class="sw ring"><div class="chip" style="background:#E3DCD0"></div><div class="meta"><div class="nm">Hairline</div><div class="hex">#E3DCD0</div><div class="tok">--line</div></div></div>
      <div class="sw ring"><div class="chip" style="background:#CFC6B8"></div><div class="meta"><div class="nm">Rule strong</div><div class="hex">#CFC6B8</div><div class="tok">--line-strong</div></div></div>
    </div>
  </div>
</section>

<!-- INK -->
<section class="pal-sec">
  <div class="wrap">
    <h2>Ink &amp; text</h2>
    <p class="sub">A warm, slightly maroon-tinted greyscale for body copy and labels.</p>
    <div class="swatches">
      <div class="sw"><div class="chip" style="background:#251319"></div><div class="meta"><div class="nm">Ink</div><div class="hex">#251319</div><div class="tok">--ink</div></div></div>
      <div class="sw"><div class="chip" style="background:#5C4A50"></div><div class="meta"><div class="nm">Ink mid</div><div class="hex">#5C4A50</div><div class="tok">--ink-mid</div></div></div>
      <div class="sw"><div class="chip" style="background:#76646B"></div><div class="meta"><div class="nm">Ink dim</div><div class="hex">#76646B</div><div class="tok">--ink-dim</div></div></div>
      <div class="sw"><div class="chip" style="background:#B7AAAF"></div><div class="meta"><div class="nm">Ink faint</div><div class="hex">#B7AAAF</div><div class="tok">--ink-faint</div></div></div>
    </div>
  </div>
</section>

<!-- SECONDARY -->
<section class="pal-sec">
  <div class="wrap">
    <h2>Secondary accent</h2>
    <p class="sub">Each option is a KOIOS brand-book colour &mdash; also the &ldquo;positive / synced&rdquo; data signal (Q-index trend, ticks, the hero line). The left chip is the on-paper tone, the right its on-maroon tint. <b>Vibrant orange</b> is the production choice. For the two pale brand pastels &mdash; <b>Bubbly pink</b> and <b>Sky blue</b> &mdash; the book colour becomes the bright tint and the on-paper tone is a deepened in-family sibling so a hairline line still reads on cream.</p>
    <div class="swatches">
      <div class="sw"><div class="pair"><span style="background:#D25137"></span><span style="background:#E5704F"></span></div><div class="meta"><div class="nm">Vibrant orange <span class="star">&#9733;</span></div><div class="hex">#D25137 / #E5704F</div><div class="tok">PMS 7625 C &middot; --secondary</div></div></div>
      <div class="sw"><div class="pair"><span style="background:#DC9A61"></span><span style="background:#ECB079"></span></div><div class="meta"><div class="nm">Fresh yellow</div><div class="hex">#DC9A61 / #ECB079</div><div class="tok">PMS 1365 C</div></div></div>
      <div class="sw"><div class="pair"><span style="background:#2A634D"></span><span style="background:#5B9C7E"></span></div><div class="meta"><div class="nm">Wood green</div><div class="hex">#2A634D / #5B9C7E</div><div class="tok">PMS 7727 C</div></div></div>
      <div class="sw"><div class="pair"><span style="background:#C07A98"></span><span style="background:#E4C1D5"></span></div><div class="meta"><div class="nm">Bubbly pink</div><div class="hex">#C07A98 / #E4C1D5</div><div class="tok">PMS 217 C &middot; base deepened</div></div></div>
      <div class="sw"><div class="pair"><span style="background:#8089AD"></span><span style="background:#CCD2EA"></span></div><div class="meta"><div class="nm">Sky blue</div><div class="hex">#8089AD / #CCD2EA</div><div class="tok">PMS 7444 C &middot; base deepened</div></div></div>
    </div>
    <div class="legend"><span class="d" style="background:#D25137"></span> Left = on paper &middot; right = on maroon.</div>
  </div>
</section>

<!-- SEMANTIC -->
<section class="pal-sec">
  <div class="wrap">
    <h2>Semantic signals</h2>
    <p class="sub">Straight from the brand book &mdash; <b>Wood green</b>, <b>Fresh yellow</b> and <b>Vibrant orange</b> &mdash; reserved strictly for meaning, never decoration. A clean traffic-light read, independent of the secondary accent.</p>
    <div class="swatches">
      <div class="sw"><div class="chip" style="background:#2A634D"></div><div class="meta"><div class="nm">Positive</div><div class="hex">#2A634D</div><div class="tok">--positive &middot; Wood green</div></div></div>
      <div class="sw"><div class="chip" style="background:#DC9A61"></div><div class="meta"><div class="nm">Warning</div><div class="hex">#DC9A61</div><div class="tok">--amber &middot; Fresh yellow</div></div></div>
      <div class="sw"><div class="chip" style="background:#D25137"></div><div class="meta"><div class="nm">Negative</div><div class="hex">#D25137</div><div class="tok">--red &middot; Vibrant orange</div></div></div>
    </div>
  </div>
</section>

<!-- IN CONTEXT -->
<section class="pal-sec">
  <div class="wrap">
    <h2>In context</h2>
    <p class="sub">How the secondary reads against maroon and paper.</p>
    <div class="features" style="margin-top:24px">
      <div class="card" style="display:flex;flex-direction:column;gap:14px">
        <span class="mono-label">Q-index trend</span>
        <svg viewBox="0 0 240 70" preserveAspectRatio="none" style="width:100%;height:64px">
          <polyline points="0,54 40,50 80,56 120,40 160,46 200,30 240,22" fill="none" stroke="var(--secondary)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <div style="display:flex;gap:14px;align-items:center;font-family:var(--font-mono);font-size:12px;color:var(--ink-mid)">
          <span style="color:var(--secondary)">&uarr; 6 pts</span>
          <span style="width:9px;height:9px;border-radius:999px;background:var(--secondary)"></span> synced
        </div>
      </div>
      <div class="card dark" style="background:var(--primary);color:#fff;display:flex;flex-direction:column;gap:12px">
        <span class="eyebrow on-dark">On maroon</span>
        <p style="font-family:var(--font-display);font-size:22px;color:#fff;line-height:1.3">Steadier mornings, measured.</p>
        <span style="font-family:var(--font-mono);font-size:12px;color:var(--secondary-bright)">&mdash; secondary-bright reads here</span>
      </div>
      <div class="card" style="display:flex;flex-direction:column;gap:12px">
        <span class="mono-label">Buttons</span>
        <a class="btn btn--primary" style="justify-content:center">Primary &mdash; maroon</a>
        <a class="btn btn--ghost" style="justify-content:center">Ghost</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style is:global>
  .pal-hero{padding:clamp(40px,5vw,64px) 0 12px}
  .pal-hero h1{white-space:nowrap}
  @media(max-width:560px){.pal-hero h1{white-space:normal}}
  .pal-sec{padding:0 0 calc(40px*var(--density))}
  .pal-sec h2{font-size:clamp(24px,3vw,32px)}
  .pal-sec .sub{font-size:15px;color:var(--ink-mid);margin-top:8px;max-width:60ch}
  .swatches{display:grid;grid-template-columns:repeat(auto-fill,minmax(166px,1fr));gap:16px;margin-top:26px}
  .sw{background:var(--surface-2);border:1px solid var(--line);border-radius:var(--radius);overflow:hidden}
  .sw .chip{height:88px;border-bottom:1px solid rgba(0,0,0,.05)}
  .sw .meta{padding:13px 14px}
  .sw .nm{font-size:14px;font-weight:600;color:var(--ink)}
  .sw .nm .star{color:var(--secondary);font-weight:700}
  .sw .hex{font-family:var(--font-mono);font-size:11.5px;color:var(--ink-mid);margin-top:5px;text-transform:uppercase;letter-spacing:.02em}
  .sw .tok{font-family:var(--font-mono);font-size:10.5px;color:var(--ink-dim);margin-top:3px}
  .sw.ring .chip{box-shadow:inset 0 0 0 1px var(--line)}
  .pair{display:flex}
  .pair span{flex:1;height:88px}
  .legend{display:flex;gap:10px;align-items:center;font-family:var(--font-mono);font-size:11px;
    letter-spacing:.04em;color:var(--ink-dim);margin-top:14px}
  .legend .d{width:10px;height:10px;border-radius:3px}
</style>
