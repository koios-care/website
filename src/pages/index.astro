---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getFeaturedQuotes, getStats, getPartners } from '../sanity/lib/content';

// Sanity-managed testimonials (first 3 featured); falls back to launch copy
const cmsQuotes = await getFeaturedQuotes();
const quotes = cmsQuotes ?? [
  { text: 'In my current scheme, sometimes I forget that I have Parkinson’s.', attribution: 'Person living with Parkinson’s, 53' },
  { text: 'Koios helps me identify a patient’s pains quickly and offer better care.', attribution: 'A.G. · Clinician' },
  { text: 'Sharing objective data with my doctor has improved our conversations significantly.', attribution: 'Bert, 55 · Ghent' },
];

const cmsStats = await getStats();
const stats = cmsStats ?? [
  { value: '57%', label: 'reported improvement in health-related quality of life' },
  { value: '96%', label: "of patients’ days captured passively, with no added effort" },
  { value: '40+', label: 'validated digital measures of neurological & body health' },
  { value: '8', label: 'hospital & research partners across Belgium' },
];

const cmsPartners = await getPartners();
const partners = cmsPartners ?? [
  { name: 'AZ Delta', kind: 'hospital' },
  { name: 'AZ Groeninge', kind: 'hospital' },
  { name: 'AZ Oostende', kind: 'hospital' },
  { name: 'CHU Liège', kind: 'hospital' },
  { name: 'CHU Charleroi', kind: 'hospital' },
  { name: 'imec.istart', kind: 'backer' },
  { name: 'VLAIO', kind: 'backer' },
];

// Investors & funders behind the seed round (logos from the founders' material).
// Lead investor first.
const INVESTORS = [
  { name: 'Evercurious VC', logo: '/investors/evercurious.png' },
  { name: 'Astylab Ventures', logo: '/investors/astylab.png' },
  { name: 'imec.istart', logo: '/investors/imec.jpeg' },
  { name: 'VLAIO', logo: '/investors/vlaio.jpeg' },
  { name: 'BlueHealth Innovation Fund', logo: '/investors/bhif.jpeg' },
  { name: 'Lumiares', logo: '/investors/lumiares.jpeg' },
];
---
<BaseLayout
  title="Koios · Neurology that runs on data, not memory"
  description="Koios turns the phone and watch people already wear into clinically meaningful measures of life with Parkinson's — an objective view of every day, well beyond the clinic visit."
  page="home"
>

<!-- HERO — animated tremor line -->
<section class="ahero" id="ahero" data-screen-label="Hero">
  <canvas id="tremor"></canvas>
  <!-- fundraise announcement — sits between the navbar and the eyebrow -->
  <div class="fund-pill" id="fundPill" hidden>
    <a href="/press-release">
      <span class="dot"></span>
      <span class="lbl">News</span>
      &euro;1M seed raised &mdash; read the announcement <span class="arr">&rarr;</span>
    </a>
    <button id="fundDismiss" aria-label="Dismiss">&#x2715;</button>
  </div>
  <div class="ahero-top" id="aheroTop">
    <span class="eyebrow">AI-native digital medicine</span>
    <h1>Parkinson&rsquo;s care that runs on <em>data</em>, not memory.</h1>
  </div>
  <div class="ahero-zone" id="aheroZone" aria-hidden="true"></div>
  <div class="ahero-bottom" id="aheroDock">
    <p class="sub">Koios reads the everyday signal of life with Parkinson&rsquo;s and turns the noise into something steady &mdash; objective measures, every day, not just at the clinic.</p>
    <div class="ahero-actions">
      <a href="/patients" class="btn btn--on-dark">Get Parkiwatch <span class="arr">&rarr;</span></a>
      <a href="#how" class="btn btn--ghost on-dark">See how it works</a>
    </div>
  </div>
</section>

<!-- THE GAP -->
<section class="dark" id="gap" data-screen-label="The gap">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow on-dark">The gap</span>
      <h2>Two visits a year. Eight thousand hours of life.</h2>
    </div>
    <div class="gap-grid">
      <div class="reveal">
        <!-- a year, one box per day — starts zoomed in on a clinic visit,
             then pulls back to show how little of the year the clinic sees -->
        <div class="gap-days" aria-hidden="true">
          <div class="gd-viewport" id="gdViewport">
            <div class="gd-grid" id="gdGrid">
              {Array.from({ length: 365 }, (_, i) => (
                <i class={i === 74 || i === 257 ? 'visit' : undefined}></i>
              ))}
            </div>
          </div>
          <div class="gd-legend">
            <span><i class="visit"></i> seen at the clinic &mdash; 2 days</span>
            <span><i></i> recalled from memory &mdash; 363 days</span>
          </div>
        </div>
        <div class="gap-stat">~0.6%<span>of a year with Parkinson&rsquo;s is spent in front of a neurologist. The rest is recalled from memory at the next appointment.</span></div>
      </div>
      <div class="gap-copy reveal" data-delay="1">
        <p>Neurology runs on snapshots: a short exam, a questionnaire, and a patient trying to recall how a hard month felt. But symptoms shift hour to hour, and quality of life is difficult to capture in a fifteen-minute appointment.</p>
        <p>So medication gets adjusted slowly, decline shows up late, and no one can measure whether care is working. Koios covers that gap &mdash; turning the time between visits into objective data that patients and clinicians can act on.</p>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section id="how" data-screen-label="How it works">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">How Koios works</span>
      <h2>Everyday devices. Clinically meaningful signal.</h2>
      <p class="lead">No clinic-grade hardware. No clunky wearables. No daily diary to fill in. Just the phone and smartwatch people already own.</p>
    </div>
    <div class="steps">
      <div class="card step reveal">
        <div class="num">1</div>
        <h3>Wear what you already wear</h3>
        <p>A smartphone and a smartwatch. Parkiwatch runs quietly in the background &mdash; no tasks to complete, no change to daily routine.</p>
      </div>
      <div class="card step reveal" data-delay="1">
        <div class="num">2</div>
        <h3>Turn movement into measures</h3>
        <p>Gait, tremor, sleep, activity and heart-rate physiology become 40+ validated digital measures of neuro, brain and body health.</p>
      </div>
      <div class="card step reveal" data-delay="2">
        <div class="num">3</div>
        <h3>Track quality of life with the Q-index</h3>
        <p>One clear index shows how quality of life changes over time. Patients can share it with their care team to help guide treatment.</p>
      </div>
    </div>
    <p class="disclaimer" style="margin-top:30px">Koios Care is a wellness solution. It is not a medical device and does not diagnose or treat disease.</p>
  </div>
</section>

<!-- EVIDENCE -->
<section style="background:var(--surface-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)" data-screen-label="Evidence">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">Early evidence</span>
      <h2>Built on science, measured in outcomes.</h2>
    </div>
    <div class="stat-grid reveal" style="margin-top:48px">
      {stats.map(s => (
        <div class="stat"><div class="v">{s.value}</div><div class="k">{s.label}</div></div>
      ))}
    </div>
  </div>
</section>

<!-- SOLUTIONS -->
<section id="solutions" data-screen-label="Who it's for">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">Who it&rsquo;s for</span>
      <h2>One platform. Three perspectives on the same life.</h2>
    </div>
    <div class="doors">
      <a href="/patients" class="card door reveal">
        <span class="tag">For patients</span>
        <h3>Understand your own days</h3>
        <p>Take Parkiwatch home and arrive at every appointment with objective data instead of trying to remember how the month went. See your own patterns, and feel more in control.</p>
        <div class="price">&euro;20 / month &middot; about the cost of a streaming subscription</div>
        <span class="go">For people with Parkinson&rsquo;s <span class="arr">&rarr;</span></span>
      </a>
      <a href="/clinicians" class="card door reveal" data-delay="1">
        <span class="tag">For clinicians</span>
        <h3>See between the visits</h3>
        <p>Remote monitoring that fits your workflow. Spot changes earlier and ground each conversation in real-world data &mdash; all from one dashboard.</p>
        <span class="go" style="margin-top:auto">For clinicians &amp; hospitals <span class="arr">&rarr;</span></span>
      </a>
      <a href="/pharma" class="card door reveal" data-delay="2">
        <span class="tag">For pharma</span>
        <h3>Objective digital endpoints</h3>
        <p>Decentralised trials with real-world measures of quality of life and disease progression. Improve compliance, capture richer evidence and cut the cost of site visits.</p>
        <span class="go" style="margin-top:auto">For pharma &amp; research <span class="arr">&rarr;</span></span>
      </a>
    </div>
  </div>
</section>

<!-- VOICES -->
<section style="background:var(--surface-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)" data-screen-label="Voices">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">In their words</span>
      <h2>The difference shows up in everyday life.</h2>
    </div>
    <div class="quotes">
      {quotes.map((q, i) => (
        <div class="card quote reveal" data-delay={i || undefined}>
          <div class="qm">&ldquo;</div>
          <p>{q.text}</p>
          <div class="who">{q.attribution}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- SCIENCE -->
<section id="science-strip" data-screen-label="Science">
  <div class="wrap science-grid">
    <div class="sec-head reveal" style="max-width:none">
      <span class="eyebrow">Science</span>
      <h2>Credibility you can cite.</h2>
      <p class="lead">A registered clinical trial, peer-reviewed publications, and hospitals across Belgium using the platform with real patients.</p>
      <div style="margin-top:28px">
        <a href="/science" class="btn btn--ghost">Read the science <span class="arr">&rarr;</span></a>
      </div>
    </div>
    <div class="reveal" data-delay="1">
      <div class="partners">
        <span class="partner">Q-index trial &middot; NCT06209502</span>
        {partners.map(p => <span class="partner">{p.name}</span>)}
      </div>
    </div>
  </div>
</section>

<!-- BACKED BY -->
<section style="background:var(--surface-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)" data-screen-label="Backed by">
  <div class="wrap">
    <div class="sec-head reveal" style="max-width:none;text-align:center">
      <span class="eyebrow no-rule" style="justify-content:center;display:flex">Backed by</span>
      <h2 style="margin-top:14px">Investors and funders behind Koios.</h2>
    </div>
    <div class="investors reveal" style="margin-top:44px">
      {INVESTORS.map((i) => (
        <div class="inv" title={i.name}><img src={i.logo} alt={i.name} loading="lazy" /></div>
      ))}
    </div>
  </div>
</section>

<!-- FINAL CTA -->
<section class="dark cta" data-screen-label="Let's talk">
  <div class="wrap reveal">
    <span class="eyebrow on-dark no-rule" style="justify-content:center;display:flex">Let&rsquo;s talk</span>
    <h2 style="margin-top:18px">Let&rsquo;s give care the full picture.</h2>
    <p class="lead">Koios turns everyday life with Parkinson&rsquo;s into evidence that patients, clinicians and researchers can act on.</p>
    <div class="hero-actions">
      <a href="/about#contact" class="btn btn--on-dark">Talk to our team <span class="arr">&rarr;</span></a>
      <a href="/patients" class="btn btn--ghost on-dark">Get Parkiwatch</a>
    </div>
  </div>
</section>

<!-- floating section nav (dots) -->
<nav class="screen-nav" id="screenNav" aria-label="Page sections"></nav>

</BaseLayout>

<style is:global>
  /* ===== animated tremor hero (dark) =====
     Layout: headline on top, the live signal line in its own band directly
     below it, supporting copy + actions underneath. The line runs on a
     gentle bottom-left → top-right diagonal and settles straight:
     tremor stabilised. */
  .ahero{position:relative;width:100%;height:calc(100svh - 72px);min-height:640px;
    display:flex;flex-direction:column;align-items:center;justify-content:center;
    text-align:center;padding:0 24px;
    overflow:hidden;background:radial-gradient(120% 95% at 68% 16%,#6E1539 0%,var(--primary) 46%,var(--primary-deep) 100%)}
  .ahero::after{content:"";position:absolute;inset:0;pointer-events:none;z-index:3;
    background:radial-gradient(130% 120% at 50% 44%,transparent 54%,rgba(20,5,12,.5) 100%)}
  .ahero canvas{position:absolute;inset:0;width:100%;height:100%;display:block;touch-action:none;z-index:2}
  .ahero-top{position:relative;z-index:4;opacity:0;transform:translateY(14px);will-change:opacity,transform}
  .ahero-top .eyebrow{color:var(--secondary-bright);justify-content:center;margin-bottom:20px}
  .ahero-top .eyebrow::before{background:var(--secondary-bright);opacity:.7}
  .ahero-top h1{color:#fff;font-size:clamp(40px,5.6vw,70px);max-width:17ch;margin:0 auto}
  .ahero-top h1 em{font-style:italic;color:var(--secondary-bright)}
  .ahero-zone{position:relative;z-index:1;height:clamp(150px,24svh,250px);width:100%;pointer-events:none}
  .ahero-bottom{position:relative;z-index:4;opacity:0;transform:translateY(14px);will-change:opacity,transform}
  .ahero-bottom .sub{margin:0 auto;font-size:clamp(16px,1.4vw,19px);line-height:1.6;
    color:var(--on-dark-dim);max-width:50ch}
  .ahero-actions{display:flex;gap:13px;justify-content:center;flex-wrap:wrap;margin-top:28px}
  @media(max-width:680px){.ahero{height:auto;min-height:100svh;padding:96px 24px 64px}
    .ahero-zone{height:190px}
    .ahero::after{display:none}}
  @media(prefers-reduced-motion:reduce){.ahero-top,.ahero-bottom{opacity:1;transform:none}}

  /* Only the landing hero holds a full screen; the rest of the page
     flows at its natural rhythm. */

  /* ===== floating section nav (dots) ===== */
  .screen-nav{position:fixed;right:18px;top:50%;transform:translateY(-50%);z-index:65;
    display:flex;flex-direction:column;gap:12px;padding:14px 9px;border-radius:999px;
    background:rgba(251,248,243,.55);border:.5px solid rgba(255,255,255,.55);
    backdrop-filter:blur(12px) saturate(140%);-webkit-backdrop-filter:blur(12px) saturate(140%);
    box-shadow:0 1px 0 rgba(255,255,255,.4) inset,0 10px 30px rgba(58,11,30,.18)}
  /* 9px visual dot, but a 28px invisible hit area for fingers */
  .screen-nav button{position:relative;width:9px;height:9px;border-radius:50%;border:0;padding:0;
    background:rgba(37,19,25,.28);cursor:pointer;transition:background .25s,transform .25s}
  .screen-nav button::before{content:"";position:absolute;inset:-10px;border-radius:50%}
  .screen-nav button:hover{background:rgba(37,19,25,.55)}
  .screen-nav button.active{background:var(--accent);transform:scale(1.35)}
  .screen-nav button:focus-visible{outline:2px solid var(--accent);outline-offset:4px}
  .screen-nav button::after{content:attr(data-label);position:absolute;right:22px;top:50%;
    transform:translateY(-50%);white-space:nowrap;font-family:var(--font-mono);font-size:10px;
    font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:#fff;
    background:var(--ink);padding:5px 10px;border-radius:6px;opacity:0;pointer-events:none;
    transition:opacity .2s}
  .screen-nav button:hover::after{opacity:1}
  @media(max-width:900px){.screen-nav{display:none}}

  /* ===== fundraise announcement pill (top of hero, under the navbar) =====
     Frosted cream glass — reads crisply against the maroon. */
  .fund-pill{position:absolute;left:50%;top:26px;transform:translate(-50%,-10px);z-index:5;
    display:flex;align-items:center;gap:4px;padding:0 6px 0 0;border-radius:999px;
    background:rgba(251,248,243,.78);border:.5px solid rgba(255,255,255,.6);
    backdrop-filter:blur(14px) saturate(150%);-webkit-backdrop-filter:blur(14px) saturate(150%);
    box-shadow:0 1px 0 rgba(255,255,255,.5) inset,0 14px 40px rgba(58,11,30,.22);
    opacity:0;transition:opacity .6s var(--ease),transform .6s var(--ease)}
  .fund-pill.show{opacity:1;transform:translate(-50%,0)}
  .fund-pill a{display:inline-flex;align-items:center;gap:9px;padding:9px 8px 9px 15px;
    font-size:13px;font-weight:500;color:var(--ink);white-space:nowrap}
  .fund-pill a:hover .arr{transform:translateX(3px)}
  .fund-pill .arr{transition:transform .22s var(--ease);color:var(--accent)}
  .fund-pill .dot{width:7px;height:7px;border-radius:50%;background:var(--secondary);
    animation:pulse 2.4s var(--ease) infinite;flex:none}
  .fund-pill .lbl{font-family:var(--font-mono);font-size:10px;font-weight:600;letter-spacing:.12em;
    text-transform:uppercase;color:var(--secondary)}
  .fund-pill button{border:0;background:transparent;color:var(--ink-dim);width:34px;height:34px;
    border-radius:50%;cursor:pointer;font-size:11px;line-height:1;flex:none;transition:background .2s,color .2s}
  .fund-pill button:hover{background:rgba(0,0,0,.06);color:var(--ink)}
  @media(max-width:680px){.fund-pill{top:14px}.fund-pill a{font-size:12px;padding-left:13px}.fund-pill .lbl{display:none}}

  /* gap */
  .gap-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(34px,5vw,60px);align-items:center;margin-top:6px}
  .gap-stat{font-family:var(--font-display);font-size:clamp(58px,8.5vw,112px);line-height:.86;
    color:#fff;letter-spacing:-.03em}
  .gap-stat span{display:block;font-family:var(--font-sans);font-size:16px;font-weight:500;
    letter-spacing:normal; /* the parent's -.03em inherits as -3.36px at 16px and mangles the caption */
    color:var(--sage-bright);margin-top:18px;line-height:1.55;max-width:34ch}
  .gap-copy p+p{margin-top:16px}
  /* the year-of-days grid: 31 columns ≈ a month per row, one box per day */
  .gap-days{margin-bottom:28px}
  .gd-viewport{overflow:hidden;border-radius:var(--radius-sm)}
  .gd-grid{display:grid;grid-template-columns:repeat(31,1fr);gap:3px;
    transform-origin:40% 21%; /* the centre of the first .visit cell (day 75) */
    transition:transform 2.2s var(--ease)}
  .gd-grid i{aspect-ratio:1;border-radius:1.5px;background:rgba(243,229,234,.14)}
  .gd-grid i.visit{background:var(--secondary-bright);
    box-shadow:0 0 12px rgba(229,112,79,.75)}
  .gd-grid.zoomed{transform:scale(9)}
  .gd-legend{display:flex;gap:22px;flex-wrap:wrap;margin-top:14px;
    font-family:var(--font-mono);font-size:11.5px;letter-spacing:.03em;color:var(--on-dark-dim)}
  .gd-legend span{display:inline-flex;align-items:center;gap:8px}
  .gd-legend i{width:10px;height:10px;border-radius:2px;background:rgba(243,229,234,.14);flex:none}
  .gd-legend i.visit{background:var(--secondary-bright)}
  @media(max-width:820px){.gap-grid{grid-template-columns:1fr;gap:30px}}

  /* steps */
  .steps{display:grid;grid-template-columns:repeat(3,1fr);gap:22px;margin-top:52px}
  .step .num{font-family:var(--font-mono);font-size:13px;font-weight:600;color:var(--accent);
    width:40px;height:40px;border:1px solid var(--line-strong);border-radius:999px;
    display:flex;align-items:center;justify-content:center}
  .step h3{font-size:22px;margin:22px 0 10px}
  .step p{font-size:15px;color:var(--ink-mid);line-height:1.6}
  .step .ico{margin-top:22px;color:var(--accent);opacity:.9}
  @media(max-width:820px){.steps{grid-template-columns:1fr}}

  /* doors */
  .doors{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:52px}
  .door{display:flex;flex-direction:column}
  .door .tag{font-family:var(--font-mono);font-size:11px;font-weight:500;letter-spacing:.12em;
    text-transform:uppercase;color:var(--accent)}
  .door h3{font-size:24px;margin:14px 0 12px}
  .door p{font-size:15px;color:var(--ink-mid);line-height:1.6;flex:1}
  .door .price{font-family:var(--font-mono);font-size:12.5px;color:var(--ink-dim);margin-top:16px;
    letter-spacing:.01em}
  .door .go{margin-top:22px}
  @media(max-width:820px){.doors{grid-template-columns:1fr}}

  /* quotes */
  .quotes{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:52px}
  .quote .qm{font-family:var(--font-display);font-size:50px;line-height:.5;color:var(--accent);opacity:.3}
  .quote p{font-family:var(--font-display);font-size:21px;line-height:1.38;color:var(--ink);
    margin:14px 0 22px;letter-spacing:-.005em}
  .quote .who{font-family:var(--font-mono);font-size:11.5px;letter-spacing:.04em;color:var(--ink-dim)}
  @media(max-width:820px){.quotes{grid-template-columns:1fr}}

  /* science */
  .science-grid{display:grid;grid-template-columns:.9fr 1.1fr;gap:clamp(32px,5vw,56px);align-items:start}
  @media(max-width:820px){.science-grid{grid-template-columns:1fr}}

  /* final cta */
  .cta{text-align:center}
  .cta h2{font-size:clamp(34px,5vw,56px);max-width:18ch;margin:0 auto}
  .cta .lead{margin:22px auto 0;text-align:center}
  .cta .hero-actions{justify-content:center;margin-top:34px}
</style>

<script>
/* ===== animated tremor hero =====
   A line that starts agitated (tremor) and settles into a steady signal —
   the metaphor for reading life with Parkinson's. The line lives in the
   band between the headline and the supporting copy. It starts as an
   agitated bottom-left → top-right diagonal and resolves to a straight,
   level line: tremor stabilised. Drag/move across it to disturb it.
   Line colour is the brand secondary (Vibrant orange). */
(function () {
  var cv = document.getElementById('tremor') as HTMLCanvasElement | null;
  if (!cv) return;
  var ctx = cv.getContext('2d')!;
  var hero = document.getElementById('ahero')!;
  var zone = document.getElementById('aheroZone')!;
  var top = document.getElementById('aheroTop')!;
  var dock = document.getElementById('aheroDock')!;
  var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  // line colour: Vibrant orange (calm tint -> agitated/hot)
  var P = { calm: [229, 112, 79], hot: [242, 133, 94] };

  var clamp = function (v: number, lo: number, hi: number) { return v < lo ? lo : v > hi ? hi : v; };
  var lerpColor = function (a: number[], b: number[], t: number) {
    return 'rgb(' + Math.round(a[0]+(b[0]-a[0])*t) + ',' + Math.round(a[1]+(b[1]-a[1])*t) + ',' + Math.round(a[2]+(b[2]-a[2])*t) + ')';
  };
  // tremorTau 0.7 → the line settles (and the text reveals) noticeably faster
  var C = { tremorTau: 0.7, calmAmp: 5, modes: [{ humps:2.5, omega:4.0, amp:24 }, { humps:4.5, omega:6.8, amp:12 }] };

  var W = 0, H = 0, dpr = 1, mid = 0, dropL = 0, riseR = 0, n = 0, spacing = 8;
  var phases: number[] = [], ripples: {x0:number,t0:number,amp:number}[] = [];
  var loadT0 = performance.now(), lastYs: number[] | null = null, settledOnce = false;

  function size() {
    dpr = Math.min(window.devicePixelRatio || 1, 2);
    var cb = cv!.getBoundingClientRect();
    W = cb.width; H = cb.height;
    cv!.width = W * dpr; cv!.height = H * dpr; ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    spacing = Math.max(6, Math.round(W / 360)); n = Math.floor(W / spacing) + 2;
    // the line's resting level = centre of the band between headline and copy
    var hr = hero.getBoundingClientRect(), zr = zone.getBoundingClientRect();
    mid = (zr.top - hr.top) + zr.height * 0.5;
    // gentle diagonal: left end sits lower, right end higher
    dropL = H * 0.10; riseR = H * 0.12;
  }
  function restart() {
    phases = C.modes.map(function () { return Math.random() * Math.PI * 2; });
    ripples = []; loadT0 = performance.now(); settledOnce = false;
    if (!reduce) {
      top.style.opacity = '0'; top.style.transform = 'translateY(14px)';
      dock.style.opacity = '0'; dock.style.transform = 'translateY(14px)';
    }
  }
  size(); restart();
  addEventListener('resize', size);

  function spawn(px: number, amp: number) {
    ripples.push({ x0: px, t0: performance.now(), amp: amp });
    if (ripples.length > 18) ripples.shift();
  }
  var lastMx: number | null = null, lastSpawnX: number | null = null;
  cv.addEventListener('pointermove', function (e) {
    var r = cv!.getBoundingClientRect(), x = e.clientX - r.left, y = e.clientY - r.top;
    var speed = 0.6; if (lastMx !== null) speed = Math.min(1.7, Math.abs(x - lastMx) / 18 + 0.5); lastMx = x;
    if (!lastYs) return;
    var idx = clamp(Math.round(x / spacing), 0, n - 1), ly = lastYs[idx];
    if (Math.abs(y - ly) < 36 && (lastSpawnX === null || Math.abs(x - lastSpawnX) > 38)) {
      spawn(x, (20 + speed * 13) * ((y < ly) ? 1 : -1)); lastSpawnX = x;
    }
  });
  cv.addEventListener('pointerleave', function () { lastMx = null; lastSpawnX = null; });
  cv.addEventListener('pointerdown', function (e) { var r = cv!.getBoundingClientRect(); spawn(e.clientX - r.left, 44 * (Math.random() < 0.5 ? -1 : 1)); });

  function rippleAt(x: number, now: number) { var s = 0; for (var i = 0; i < ripples.length; i++) { var rp = ripples[i];
    var tau = (now - rp.t0) / 1000, env = Math.exp(-1.6 * tau); if (env < 0.03) continue;
    var r = 560 * tau, front = Math.abs(x - rp.x0) - r, g = Math.exp(-(front * front) / (2 * 64 * 64));
    s += rp.amp * env * g * Math.cos(front * 0.055); } return s; }
  function rippleEnergy(now: number) { var m = 0; for (var i = 0; i < ripples.length; i++) { var rp = ripples[i];
    var e = Math.abs(rp.amp) * Math.exp(-1.6 * (now - rp.t0) / 1000); if (e > m) m = e; } return m / 30; }

  function reveal(agit: number) {
    if (!settledOnce && agit < 0.2) settledOnce = true;
    if (settledOnce) { top.style.opacity = '1'; top.style.transform = 'none'; dock.style.opacity = '1'; dock.style.transform = 'none'; return; }
    var r = clamp((0.75 - agit) / 0.5, 0, 1), e = r * r * (3 - 2 * r);
    top.style.opacity = String(e); top.style.transform = 'translateY(' + (1 - e) * 14 + 'px)';
    dock.style.opacity = String(e); dock.style.transform = 'translateY(' + (1 - e) * 14 + 'px)';
  }

  function draw(now: number) {
    var tL = (now - loadT0) / 1000, env = Math.exp(-tL / C.tremorTau);
    var agit = clamp(env + rippleEnergy(now) * 0.9, 0, 1), color = lerpColor(P.calm, P.hot, agit);
    ctx.clearRect(0, 0, W, H);
    var xs: number[] = [], ys: number[] = [];
    // the diagonal flattens as the tremor settles: agitated slope → level line
    var tilt = Math.exp(-tL / 1.1);
    for (var i = 0; i < n; i++) { var x = i * spacing, u = i / (n - 1);
      // baseline: bottom-left → top-right diagonal, resolving to horizontal at mid
      var yBase = mid + tilt * (dropL - (dropL + riseR) * u);
      var y = C.calmAmp * Math.sin(1.3 * Math.PI * u + now * 0.0011) + 2 * Math.sin(2.5 * Math.PI * u - now * 0.0007);
      for (var k = 0; k < C.modes.length; k++) { var m = C.modes[k]; y += env * m.amp * Math.sin(m.humps * Math.PI * u + m.omega * tL + phases[k]); }
      y += rippleAt(x, now); xs.push(x); ys.push(yBase + y); }
    lastYs = ys;
    ctx.lineCap = 'round'; ctx.lineJoin = 'round';
    ctx.beginPath(); ctx.moveTo(xs[0], ys[0]);
    for (var j = 1; j < n - 1; j++) ctx.quadraticCurveTo(xs[j], ys[j], (xs[j] + xs[j + 1]) / 2, (ys[j] + ys[j + 1]) / 2);
    ctx.strokeStyle = color; ctx.shadowColor = color;
    ctx.globalAlpha = 0.18; ctx.shadowBlur = 28 + agit * 22; ctx.lineWidth = 15; ctx.stroke();
    ctx.globalAlpha = 1;    ctx.shadowBlur = 10 + agit * 18; ctx.lineWidth = 3.1; ctx.stroke();
    ctx.shadowBlur = 0; ctx.strokeStyle = '#fff'; ctx.lineWidth = 1; ctx.globalAlpha = 0.1 + (1 - agit) * 0.09; ctx.stroke(); ctx.globalAlpha = 1;
    reveal(agit);
    if (ripples.length) ripples = ripples.filter(function (rp) { return Math.exp(-1.6 * (now - rp.t0) / 1000) >= 0.03; });
  }

  if (reduce) { loadT0 = performance.now() - 9999; draw(performance.now());
    top.style.opacity = '1'; top.style.transform = 'none'; dock.style.opacity = '1'; dock.style.transform = 'none';
    return; }
  (function frame(now: number) { draw(now); requestAnimationFrame(frame); })(performance.now());
})();

/* failsafe: the hero text starts hidden for the reveal — guarantee it shows
   even if the animation above ever fails to run. */
setTimeout(function () {
  ['aheroTop', 'aheroDock'].forEach(function (id) {
    var el = document.getElementById(id);
    if (el) { el.style.opacity = '1'; el.style.transform = 'none'; }
  });
}, 2000);

/* ===== gap section: a year of days, zoomed out =====
   The grid starts zoomed in on a single clinic-visit day; when scrolled
   into view it pulls back to the full year, and the two visit days all
   but disappear in the mass of unobserved days. Base state (no JS,
   reduced motion) is the fully zoomed-out year. */
(function () {
  var grid = document.getElementById('gdGrid');
  var viewport = document.getElementById('gdViewport');
  if (!grid || !viewport) return;
  if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  grid.classList.add('zoomed'); // pre-zoom before it ever scrolls into view
  // observe the fixed-size viewport, NOT the grid: at scale(9) the grid's box
  // is 9x the viewport and a 0.5 threshold could never be met.
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (en) {
      if (!en.isIntersecting) return;
      io.disconnect();
      // hold on the visit day for a beat, then pull back
      setTimeout(function () { grid.classList.remove('zoomed'); }, 500);
    });
  }, { threshold: 0.5 });
  io.observe(viewport);
})();

/* ===== floating section nav (dots) ===== */
(function () {
  var nav = document.getElementById('screenNav');
  if (!nav) return;
  var sections = Array.from(document.querySelectorAll('section[data-screen-label]')) as HTMLElement[];
  if (sections.length < 2) return;
  var dots = sections.map(function (sec, i) {
    var b = document.createElement('button');
    b.setAttribute('data-label', sec.getAttribute('data-screen-label') || 'Section ' + (i + 1));
    b.setAttribute('aria-label', sec.getAttribute('data-screen-label') || 'Section ' + (i + 1));
    b.addEventListener('click', function () { sec.scrollIntoView({ behavior: 'smooth' }); });
    nav!.appendChild(b);
    return b;
  });
  // active = the section nearest the middle of the viewport (deterministic,
  // works for sections both taller and shorter than the viewport)
  var ticking = false;
  function setActive() {
    ticking = false;
    var middle = window.innerHeight / 2, best = 0, bestDist = Infinity;
    sections.forEach(function (sec, i) {
      var r = sec.getBoundingClientRect();
      var dist = (r.top <= middle && r.bottom >= middle)
        ? 0
        : Math.min(Math.abs(r.top - middle), Math.abs(r.bottom - middle));
      if (dist < bestDist) { bestDist = dist; best = i; }
    });
    dots.forEach(function (d, i) { d.classList.toggle('active', i === best); });
  }
  function onScroll() { if (!ticking) { ticking = true; requestAnimationFrame(setActive); } }
  window.addEventListener('scroll', onScroll, { passive: true });
  window.addEventListener('resize', onScroll);
  setActive();
})();

/* ===== fundraise announcement pill =====
   Dismissing hides it for the current browsing session only (sessionStorage),
   so it returns on the next visit — never permanently gone. */
(function () {
  var pill = document.getElementById('fundPill');
  var dismiss = document.getElementById('fundDismiss');
  if (!pill || !dismiss) return;
  var KEY = 'koios:fundraise-dismissed';
  try { if (sessionStorage.getItem(KEY)) return; } catch (e) {}
  pill.hidden = false;
  setTimeout(function () { pill!.classList.add('show'); }, 800);
  dismiss.addEventListener('click', function () {
    pill!.classList.remove('show');
    try { sessionStorage.setItem(KEY, '1'); } catch (e) {}
    setTimeout(function () { pill!.hidden = true; }, 600);
  });
})();
</script>
