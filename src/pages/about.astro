---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTeam, getAdvisors, initials } from '../sanity/lib/content';

// Sanity-managed team; falls back to the real roster (names, roles, photos and
// LinkedIn from the founders' material) until/unless content is entered in Studio.
const team = await getTeam();
const FALLBACK_TEAM = [
  { name: 'Konstantinos Kyritsis, PhD', role: 'Co-founder & CEO', photoUrl: null, photo: '/team/konstantinos.jpeg', linkedin: 'https://www.linkedin.com/in/konstantinos-kyritsis-0a6b0a4a/' },
  { name: 'Dimitris Iakovakis, PhD', role: 'Co-founder & CTO', photoUrl: null, photo: '/team/di-nbg.png', linkedin: 'https://www.linkedin.com/in/iakovakis/' },
  { name: 'Vasileios Papapanagiotou, PhD', role: 'Senior R&D engineer · Professor @Karolinska', photoUrl: null, photo: '/team/vp-nbg.png', linkedin: 'https://www.linkedin.com/in/vasileios-papapanagiotou-3155b990/' },
  { name: 'Prof. MD Gaëtan Garraux', role: 'Clinical lead · Neurology professor @CHU Liège', photoUrl: null, photo: '/team/gg-nbg.png', linkedin: 'https://www.linkedin.com/in/ga%C3%ABtan-garraux-md-phd-8744b2a/' },
  { name: 'Patricia Van Rompuy', role: 'Quality & clinical trial lead', photoUrl: null, photo: '/team/pvr-nbg.png', linkedin: 'https://www.linkedin.com/in/patricia-van-rompuy-341927b/' },
  { name: 'Bram Lenaerts', role: 'Commercial lead', photoUrl: null, photo: '/team/bram.png', linkedin: 'https://www.linkedin.com/in/bram-lenaerts-83a26a20/' },
  { name: 'Apostolis Moustaklis', role: 'Junior R&D engineer', photoUrl: null, photo: '/team/AM-nbg.png', linkedin: 'https://www.linkedin.com/in/apostolos-moustaklis-941a45162/' },
];
// The CMS carries names/roles but no photo or LinkedIn, so we enrich each
// record from the local directory below (matched by normalised name). The
// same arrays also serve as the standalone fallback when the CMS is empty.

// Advisors — CMS content if present, otherwise the real advisory board.
const cmsAdvisors = await getAdvisors();
const FALLBACK_ADVISORS = [
  { name: 'Kris Schellens', role: 'ex-Director, Biogen Belgium', photoUrl: null, photo: '/team/ks-nbg.png', linkedin: 'https://www.linkedin.com/in/kris-schellens-27579710/' },
  { name: 'Lampros Kourtis, PhD', role: 'Lead of Gates Ventures ADDF · Founder & investor', photoUrl: null, photo: '/team/ik-nbg.png', linkedin: 'https://www.linkedin.com/in/lamproskourtis1977/' },
  { name: 'Gregor Strobbe, PhD', role: 'Founder & CEO of Clouds of Care', photoUrl: null, photo: '/team/gs-nbg.png', linkedin: 'https://www.linkedin.com/in/gregor-strobbe-17b37525/' },
  { name: 'Jurgen Van Broeck, MBA', role: 'CEO of mAbxience', photoUrl: null, photo: '/team/jvb-nbg.png', linkedin: 'https://www.linkedin.com/in/jurgen-van-broeck-7842ba8/' },
  { name: 'MD Jean-Briac Prévost', role: 'Clinical oncologist · Business', photoUrl: null, photo: '/team/jb-nbg.png', linkedin: 'https://www.linkedin.com/in/jean-briac-prevost-66b2131a' },
  { name: 'Hadeel Elamer', role: 'BD advisor · ex-Digital lead @Abbott', photoUrl: null, photo: '/team/hadeel.png', linkedin: 'https://www.linkedin.com/in/hadeelelamer/' },
  { name: 'Iraklis Kourtis, PhD', role: 'BD & scientific advisor · Digital strategy @Takeda', photoUrl: null, photo: '/team/iraklis.png', linkedin: 'https://www.linkedin.com/in/ikourtis/' },
  { name: 'Bjorn Delbeecke, LL.M, MBA', role: 'Regulatory strategy', photoUrl: null, photo: '/team/bjorn.png', linkedin: 'https://www.linkedin.com/in/bjorn-delbeecke-ll-m-mba-71462642/' },
];
const norm = (s: string) =>
  s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]/g, '');
const DIRECTORY = new Map(
  [...FALLBACK_TEAM, ...FALLBACK_ADVISORS].map((m) => [norm(m.name), m])
);
// keep CMS photo if it has one; otherwise graft the local photo + LinkedIn
const enrich = (m: any) => {
  const local = DIRECTORY.get(norm(m.name));
  return {
    ...m,
    photo: m.photoUrl ? null : (m.photo ?? local?.photo ?? null),
    linkedin: m.linkedin ?? local?.linkedin ?? null,
  };
};
const members = (team ?? FALLBACK_TEAM).map(enrich);
// advisors to omit from the site (matched by normalised name, any source)
const REMOVE_ADVISORS = ['hadeel', 'krisschellens', 'irakliskourtis'];
const advisors = (cmsAdvisors ?? FALLBACK_ADVISORS)
  .map(enrich)
  .filter((m) => !REMOVE_ADVISORS.some((k) => norm(m.name).includes(k)));
---
<BaseLayout
  title="Koios · About & contact"
  description="Koios builds clinically meaningful insight from the devices people already use. Starting with Parkinson's, from Antwerp."
  page="about"
>

<!-- HERO -->
<section class="page-hero">
  <div class="wrap">
    <div>
      <span class="eyebrow">About Koios</span>
      <h1 style="margin-top:18px">Care should run on <em>evidence</em>.</h1>
    </div>
    <p class="lead" style="margin-top:22px">We build clinically meaningful insight from the devices people already use &mdash; captured quietly in the background, and shared only when it helps. Starting with Parkinson&rsquo;s.</p>
  </div>
</section>

<!-- STORY -->
<section style="padding-top:calc(20px*var(--density))">
  <div class="wrap split lead-text">
    <div class="reveal">
      <span class="eyebrow">Why we exist</span>
      <h2 style="margin-top:16px">Two visits a year isn&rsquo;t a measurement.</h2>
    </div>
    <div class="story reveal" data-delay="1">
      <p>Neurology runs on snapshots &mdash; a short exam, a questionnaire, and a patient trying to recall how a hard month felt. Meanwhile symptoms shift hour to hour, and the eight thousand hours between appointments go unmeasured.</p>
      <p>Koios closes that gap. We turn everyday movement and rest into <b>objective, validated measures</b> of life with Parkinson&rsquo;s &mdash; so patients feel more in control, clinicians see earlier, and researchers gain real-world evidence.</p>
      <p>We do it with <b>no extra hardware and no daily tasks</b>, because the best measurement is the one that fits invisibly into a life.</p>
    </div>
  </div>
</section>

<!-- VALUES -->
<section style="background:var(--surface-2);border-top:1px solid var(--line);border-bottom:1px solid var(--line)">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">How we work</span>
      <h2>Principles we hold to.</h2>
    </div>
    <div class="values reveal">
      <div class="card value">
        <div class="n">01</div>
        <h3 style="margin-top:14px">Objective over anecdotal</h3>
        <p>Every claim should trace back to a validated measure. We earn trust with evidence, not adjectives.</p>
      </div>
      <div class="card value">
        <div class="n">02</div>
        <h3 style="margin-top:14px">Invisible by design</h3>
        <p>The best measurement asks nothing of the patient. No tasks, no diaries, no devices to charge.</p>
      </div>
      <div class="card value">
        <div class="n">03</div>
        <h3 style="margin-top:14px">Patient owns the data</h3>
        <p>Data is private by default and shared only when the person chooses. Their condition, their call.</p>
      </div>
    </div>
  </div>
</section>

<!-- TEAM -->
<section>
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="eyebrow">The team</span>
      <h2>Clinicians, engineers and scientists.</h2>
      <p class="lead">A small team working closely with neurologists across Belgium.</p>
    </div>
    <div class="team-grid reveal">
      {members.map((m) => (
        <div class="member">
          <div class="photo">
            {m.photoUrl
              ? <img src={`${m.photoUrl}?w=600&h=600&fit=crop&auto=format`} alt={m.name} loading="lazy" />
              : 'photo' in m && m.photo
                ? <img src={m.photo} alt={m.name} loading="lazy" />
                : <span>{initials(m.name)}</span>}
          </div>
          <h4>{m.name}</h4>
          <div class="role">{m.role}</div>
          {'linkedin' in m && m.linkedin && (
            <a class="member-li" href={m.linkedin} target="_blank" rel="noopener" aria-label={`${m.name} on LinkedIn`}>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
              <span>LinkedIn</span>
            </a>
          )}
        </div>
      ))}
    </div>
    {advisors && (
      <div style="margin-top:72px">
        <div class="sec-head reveal">
          <span class="eyebrow">Advisors</span>
          <h2>Our advisors.</h2>
        </div>
        <div class="team-grid reveal">
          {advisors.map((m) => (
            <div class="member">
              <div class="photo">
                {m.photoUrl
                  ? <img src={`${m.photoUrl}?w=600&h=600&fit=crop&auto=format`} alt={m.name} loading="lazy" />
                  : 'photo' in m && m.photo
                    ? <img src={m.photo} alt={m.name} loading="lazy" />
                    : <span>{initials(m.name)}</span>}
              </div>
              <h4>{m.name}</h4>
              <div class="role">{m.role}</div>
              {'linkedin' in m && m.linkedin && (
                <a class="member-li" href={m.linkedin} target="_blank" rel="noopener" aria-label={`${m.name} on LinkedIn`}>
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.34V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/></svg>
                  <span>LinkedIn</span>
                </a>
              )}
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<!-- CONTACT -->
<section id="contact">
  <div class="wrap contact-grid">
    <div class="reveal">
      <span class="eyebrow">Get in touch</span>
      <h2 style="margin-top:16px">Let&rsquo;s talk.</h2>
      <p class="lead" style="margin-top:18px">Whether you&rsquo;re living with Parkinson&rsquo;s, caring for patients, or running a study &mdash; we&rsquo;d love to hear from you.</p>
      <ul class="contact-meta" style="margin-top:28px">
        <li><div class="k">Email</div><div class="v"><a href="mailto:info@koios.care">info@koios.care</a></div></li>
        <li><div class="k">Office</div><div class="v">Filip Williotstraat 9<br/>2600 Antwerpen, Belgium</div></li>
        <li><div class="k">Company</div><div class="v">Koios Care &middot; <span class="mono">VAT BE0786.830.148</span></div></li>
      </ul>
    </div>
    <div class="reveal" data-delay="1">
      <div class="card" style="padding:32px 30px">
        <form class="contact-form" id="contactForm" novalidate>
          <div class="row-2">
            <div class="field"><label for="cf-name">Name</label><input id="cf-name" type="text" required placeholder="Your name" /></div>
            <div class="field"><label for="cf-email">Email</label><input id="cf-email" type="email" required placeholder="you@example.com" /></div>
          </div>
          <div class="field">
            <label for="cf-role">I am a&hellip;</label>
            <select id="cf-role">
              <option>Person with Parkinson&rsquo;s / family</option>
              <option>Clinician or hospital</option>
              <option>Pharma or research partner</option>
              <option>Investor</option>
              <option>Other</option>
            </select>
          </div>
          <div class="field"><label for="cf-msg">Message</label><textarea id="cf-msg" rows="4" placeholder="How can we help?"></textarea></div>
          <button type="submit" class="btn btn--primary" style="justify-content:center">Send message <span class="arr">&rarr;</span></button>
        </form>
        <div class="form-ok" id="formOk">Thanks &mdash; your email app should now open with your message ready to send to <a href="mailto:info@koios.care">info@koios.care</a>. If it didn&rsquo;t open, please email us directly.</div>
      </div>
    </div>
  </div>
</section>

</BaseLayout>

<style is:global>
  .story p{font-size:clamp(18px,1.6vw,21px);line-height:1.6;color:var(--ink-mid);max-width:62ch}
  .story p+p{margin-top:20px}
  .story p b{color:var(--ink);font-weight:600}
  .values{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:48px}
  .value h3{font-size:20px;margin-bottom:10px}
  .value p{font-size:15px;color:var(--ink-mid);line-height:1.6}
  .value .n{font-family:var(--font-mono);font-size:11px;color:var(--accent);letter-spacing:.1em}
  @media(max-width:820px){.values{grid-template-columns:1fr}}
  .member-li{display:inline-flex;align-items:center;gap:6px;margin-top:10px;
    font-family:var(--font-mono);font-size:11px;letter-spacing:.04em;color:var(--ink-dim);transition:color .2s}
  .member-li svg{opacity:.7;transition:opacity .2s}
  .member-li:hover{color:var(--accent)}
  .member-li:hover svg{opacity:1}
  .contact-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:clamp(36px,5vw,60px);align-items:start}
  @media(max-width:860px){.contact-grid{grid-template-columns:1fr;gap:40px}}
  .contact-meta li{list-style:none;margin-bottom:18px}
  .contact-meta .k{font-family:var(--font-mono);font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-dim)}
  .contact-meta .v{font-size:16px;color:var(--ink);margin-top:5px}
  .contact-meta a:hover{color:var(--accent)}
  .form-ok{background:var(--sage-faint);border:1px solid var(--sage);border-radius:var(--radius);
    padding:24px;color:var(--sage);font-size:15px;display:none}
</style>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement | null;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const name = document.getElementById('cf-name') as HTMLInputElement;
      const email = document.getElementById('cf-email') as HTMLInputElement;
      let ok = true;
      [name, email].forEach((f) => {
        if (!f.value.trim()) { f.style.borderColor = 'var(--red)'; ok = false; }
        else f.style.borderColor = '';
      });
      if (email.value && !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email.value)) { email.style.borderColor = 'var(--red)'; ok = false; }
      if (!ok) return;

      // No backend — hand the message to the visitor's own mail client.
      const role = (document.getElementById('cf-role') as HTMLSelectElement | null)?.value ?? '';
      const msg = (document.getElementById('cf-msg') as HTMLTextAreaElement | null)?.value ?? '';
      const subject = `Website enquiry — ${name.value.trim()}`;
      const body =
        `Name: ${name.value.trim()}\n` +
        `Email: ${email.value.trim()}\n` +
        `I am a: ${role}\n\n` +
        `${msg}\n`;
      const mailto =
        `mailto:info@koios.care?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;

      form.style.display = 'none';
      const okEl = document.getElementById('formOk');
      if (okEl) okEl.style.display = 'block';
      window.location.href = mailto;
    });
  }
</script>
