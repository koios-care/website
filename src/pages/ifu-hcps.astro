---
import BaseLayout from '../layouts/BaseLayout.astro';
import IfuDocument from '../components/IfuDocument.astro';
---
<BaseLayout
  title="Koios · Instructions for use — healthcare professionals"
  description="The official Parkiwatch instructions for use for healthcare professionals — available in English, Dutch and French."
  page="ifu-hcps"
>

<!-- HERO -->
<section class="page-hero">
  <div class="wrap">
    <div>
      <span class="eyebrow">Instructions for use</span>
      <h1 style="margin-top:18px">For healthcare <em>professionals</em>.</h1>
    </div>
    <p class="lead" style="margin-top:22px">The official instructions for use for the Parkiwatch system, intended for healthcare professionals. A separate guide exists for people with Parkinson&rsquo;s disease.</p>
  </div>
</section>

<!-- DOCUMENT -->
<section style="padding-top:calc(20px*var(--density))">
  <div class="wrap">
    <IfuDocument slug="ifu-hcps" docTitle="Parkiwatch instructions for use — healthcare professionals" />
    <p class="ifu-cross reveal">Looking for the patient guide? See the <a href="/ifu-patients">instructions for use for people with Parkinson&rsquo;s</a> &middot; or check <a href="/compatibility">which smartwatches are compatible</a>.</p>
  </div>
</section>

</BaseLayout>

<style is:global>
  .ifu-cross{margin-top:22px;font-size:14.5px;color:var(--ink-mid)}
  .ifu-cross a{color:var(--primary);font-weight:500;border-bottom:1px solid var(--line-strong)}
  .ifu-cross a:hover{border-bottom-color:var(--primary)}
</style>
