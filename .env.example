# ── Sanity Visual Editing (optional) ────────────────────────────────────────
#
# Set these to enable the Presentation tab in Sanity Studio and live draft
# preview with click-to-edit overlays.  Leave unset for the normal static
# production build (stega-free, published content only).
#
# 1. Create a Viewer token:
#    https://www.sanity.io/manage/project/lw88pa2w -> API -> Tokens -> Add API token
#    Role: Viewer (read-only; never use an Editor/Admin token here)
#
# 2. Copy this file to .env and fill in the values:
#    cp .env.example .env.development
#
# 3. Run the dev server with visual editing active:
#    npm run dev
#    Then open http://localhost:4321/admin -> Presentation

PUBLIC_SANITY_VISUAL_EDITING_ENABLED=true
SANITY_API_READ_TOKEN=<paste-viewer-token-here>

# Optional: override the preview URL the Presentation tool opens.
# Defaults to http://localhost:4321 (the Astro dev server).
# SANITY_STUDIO_PREVIEW_URL=http://localhost:4321
